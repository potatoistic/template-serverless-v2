{
  "name": "serverless-template",
  "version": "1.0.0",
  "description": "A Basic template for serverless lambda with typescript support",
  "main": ".dist/index.js",
  "scripts": {
    "start": "sls offline start",
    "package": "sls package",
    "build": "tsc",
    "watch": "concurrently \"tsc --watch\" \"sls offline start --reloadHandler\"",
    "clean": "rimraf .webpack .dist .serverless",
    "clean:deep": "rimraf node_modules .webpack .serverless .dist",
    "migrate": "drizzle-kit generate:mysql"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.111",
    "@types/node": "^18.14.6",
    "concurrently": "^7.6.0",
    "drizzle-kit": "^0.17.0",
    "rimraf": "^4.4.0",
    "serverless": "^3.28.1",
    "serverless-bundle": "^6.0.0",
    "serverless-jetpack": "^0.11.1",
    "serverless-offline": "^12.0.4",
    "serverless-prune-plugin": "^2.0.2",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "dayjs": "^1.11.7",
    "drizzle-orm": "^0.21.1",
    "mysql2": "^2.3.3",
    "zod": "^3.21.4"
  }
}
